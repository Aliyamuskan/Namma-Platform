<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/high_contrast_yellow">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/deep_railway_blue"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white"
            app:title="@string/select_language"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/tvSelectLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/select_language"
        android:textAlignment="center"
        android:textColor="@color/deep_railway_blue"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKannada"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/kannada"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/deep_railway_blue"
        app:backgroundTint="@color/railway_yellow"
        app:cornerRadius="16dp"
        app:strokeColor="@color/deep_railway_blue"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectLanguage" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnglish"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/english"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/deep_railway_blue"
        app:backgroundTint="@color/railway_yellow"
        app:cornerRadius="16dp"
        app:strokeColor="@color/deep_railway_blue"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/btnKannada" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHindi"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/hindi"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/deep_railway_blue"
        app:backgroundTint="@color/railway_yellow"
        app:cornerRadius="16dp"
        app:strokeColor="@color/deep_railway_blue"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/btnEnglish" />

</androidx.constraintlayout.widget.ConstraintLayout>