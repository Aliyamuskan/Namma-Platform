<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/high_contrast_yellow">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/deep_railway_blue"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white"
            app:title="@string/emergency_help_title"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/emergency_contacts_header"
            android:textColor="@color/emergency_red"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black" />

        <!-- Police Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPolice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/deep_railway_blue"
            app:strokeWidth="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="20dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@android:drawable/ic_menu_call" app:tint="@color/deep_railway_blue" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/railway_police" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="@color/deep_railway_blue" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/railway_police_desc" android:textSize="18sp" android:textColor="@color/black" android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Medical Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMedical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/emergency_red"
            app:strokeWidth="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="20dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@android:drawable/ic_menu_call" app:tint="@color/emergency_red" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/medical_help" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="@color/emergency_red" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/medical_help_desc" android:textSize="18sp" android:textColor="@color/black" android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- General Help Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHelpLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/deep_railway_blue"
            app:strokeWidth="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="20dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/deep_railway_blue" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/helpline" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="@color/deep_railway_blue" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/helpline_desc" android:textSize="18sp" android:textColor="@color/black" android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>