<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/high_contrast_yellow"
    android:padding="16dp">

    <!-- Station Selection -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilStation"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/select_station"
        app:boxStrokeColor="@color/deep_railway_blue"
        app:hintTextColor="@color/deep_railway_blue"
        app:layout_constraintTop_toTopOf="parent">

        <AutoCompleteTextView
            android:id="@+id/actvStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/black" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Platform Indicator -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPlatform"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/deep_railway_blue"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/railway_yellow"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/tilStation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/platform_number"
                android:textColor="@color/railway_yellow"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvPlatformNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/white"
                android:textSize="80sp"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Coach Layout Section -->
    <TextView
        android:id="@+id/tvCoachHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/coach_position"
        android:textColor="@color/deep_railway_blue"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardPlatform" />

    <HorizontalScrollView
        android:id="@+id/hsvCoachLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvCoachHeader">

        <LinearLayout
            android:id="@+id/llCoachContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp" />
    </HorizontalScrollView>

    <!-- Help Me Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHelp"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="32dp"
        android:text="@string/help_me"
        android:textSize="24sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/deep_railway_blue"
        app:backgroundTint="@color/railway_yellow"
        app:strokeColor="@color/deep_railway_blue"
        app:strokeWidth="2dp"
        app:icon="@android:drawable/ic_btn_speak_now"
        app:iconTint="@color/deep_railway_blue"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="44dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>