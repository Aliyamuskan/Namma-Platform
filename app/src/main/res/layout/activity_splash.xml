<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_railway_blue">

    <!-- Background Decoration: Subtle Track Lines -->
    <View
        android:id="@+id/trackLine1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginBottom="80dp"
        android:alpha="0.2"
        android:background="@color/railway_yellow"
        app:layout_constraintBottom_toBottomOf="parent" />

    <View
        android:id="@+id/trackLine2"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginBottom="105dp"
        android:alpha="0.2"
        android:background="@color/railway_yellow"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Center Content Grouped for Perfect Alignment -->
    <LinearLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="160dp"
            android:layout_height="100dp"
            android:padding="8dp"
            android:src="@drawable/ic_coach_engine"
            app:tint="@color/railway_yellow"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="@string/app_name"
            android:textAllCaps="true"
            android:textColor="@color/railway_yellow"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/splash_subtitle"
            android:textColor="@color/railway_yellow"
            android:textSize="16sp"
            android:alpha="0.9" />

    </LinearLayout>

    <!-- Animated Train at the bottom -->
    <ImageView
        android:id="@+id/animatedTrain"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_coach_engine"
        android:layout_marginBottom="85dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/railway_yellow"
        android:translationX="-150dp"
        tools:ignore="ContentDescription" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="160dp"
        android:layout_height="4dp"
        android:layout_marginBottom="48dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/railway_yellow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSafeTravels"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-light"
        android:text="@string/splash_safe_travels"
        android:textColor="@color/railway_yellow"
        android:textSize="14sp"
        android:alpha="0.7"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>