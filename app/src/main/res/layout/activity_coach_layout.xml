<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_railway_blue">

    <!-- Header Section -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/dark_navy_blue"
            app:title="@string/coach_layout_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Train Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTrainDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/dark_navy_blue"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:strokeColor="@color/railway_yellow"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTrainName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/train_name_demo"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvTrainNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/train_number_demo"
                android:textColor="@color/railway_yellow"
                android:fontFamily="sans-serif-medium"
                android:textSize="18sp"
                android:alpha="0.9" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/railway_yellow"
                android:alpha="0.3" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/railway_yellow" />
                    <TextView
                        android:id="@+id/tvPlatform"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_platform_circle"
                        android:backgroundTint="@color/railway_yellow"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="Platform: 2"
                        android:textColor="@color/dark_navy_blue"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/railway_yellow" />
                    <TextView
                        android:id="@+id/tvArrival"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Arrival: 5:40 PM"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="On Time"
                    android:textColor="@color/status_on_time"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/railway_yellow" />
                    <TextView
                        android:id="@+id/tvDeparture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Departure: 5:50 PM"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvEngineSide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:text="@string/engine_side_label"
        android:textColor="@color/railway_yellow"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardTrainDetails" />

    <!-- Coach Layout Horizontal Scroll -->
    <HorizontalScrollView
        android:id="@+id/hsvCoachLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvEngineSide">

        <LinearLayout
            android:id="@+id/llCoachContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="bottom" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvGuidanceMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="@string/general_guidance_msg"
        android:textColor="@color/railway_yellow"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/hsvCoachLayout" />

    <!-- Buttons Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeakKannada"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_speak_kannada"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/railway_yellow"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconSize="28dp"
            app:iconTint="@color/dark_navy_blue"
            android:textColor="@color/dark_navy_blue"
            app:rippleColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlatformNav"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_platform_nav"
            android:textSize="18sp"
            android:textStyle="bold"
            app:strokeColor="@color/railway_yellow"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_directions"
            app:iconSize="28dp"
            app:iconTint="@color/railway_yellow"
            android:textColor="@color/railway_yellow"
            app:rippleColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHome"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_back_home"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/railway_yellow"
            app:rippleColor="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>