<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- The Coach Body -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCoachBody"
        android:layout_width="85dp"
        android:layout_height="65dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/railway_yellow"
        app:strokeWidth="1.5dp"
        app:cardBackgroundColor="@color/dark_navy_blue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/ivCoachIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="fitCenter"
                android:contentDescription="Coach Icon"
                app:tint="@color/railway_yellow" />

            <TextView
                android:id="@+id/tvCoachLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:text="S1" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Wheels for the Train Effect -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_platform_circle"
            android:backgroundTint="@color/railway_yellow" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_platform_circle"
            android:backgroundTint="@color/railway_yellow" />
    </LinearLayout>

</LinearLayout>